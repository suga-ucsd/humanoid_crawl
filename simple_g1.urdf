  </link>

  <joint name="right_knee_joint" type="revolute">
    <origin xyz="-0.078273 -0.0021489 -0.17734" rpy="0 0.1745 0"/>
    <parent link="right_hip_yaw_link"/>
    <child link="right_knee_link"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.087267" upper="2.8798" effort="139" velocity="10"/>
    <dynamics damping="3.0" friction="0.0"/>
  </joint>
  <link name="right_knee_link">
    <inertial>
      <origin xyz="0.005 -0.004 -0.121" rpy="0 0 0"/>
      <mass value="1.932"/>
      <inertia ixx="0.01138" ixy="0" ixz="0"
                              iyy="0.01128" iyz="0"
                                            izz="0.00146"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.150" rpy="0 0 0"/>
