      <inertia ixx="0.00255" ixy="0" ixz="0"
                              iyy="0.00241" iyz="0"
                                            izz="0.00149"/>
    </inertial>
    <visual>
      <origin xyz="0.015 0 -0.062" rpy="0 0 0"/>
