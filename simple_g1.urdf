  </link>

  <!-- knee: pos=(-0.078273, 0.0021489, -0.17734) rpy=(0, +0.1745, 0) -->
  <joint name="left_knee_joint" type="revolute">
    <origin xyz="-0.078273 0.0021489 -0.17734" rpy="0 0.1745 0"/>
    <parent link="left_hip_yaw_link"/>
    <child link="left_knee_link"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.087267" upper="2.8798" effort="139" velocity="10"/>
    <dynamics damping="3.0" friction="0.0"/>
