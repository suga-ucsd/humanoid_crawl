  </link>

  <!-- hip_roll: rpy=(0, -0.1745, 0) — same as left (symmetric kinematic) -->
  <joint name="right_hip_roll_joint" type="revolute">
    <origin xyz="0 -0.052 -0.030465" rpy="0 -0.1745 0"/>
    <parent link="right_hip_pitch_link"/>
